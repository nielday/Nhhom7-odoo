<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tasks for Task Management -->
    
    <!-- Tasks cho Order 001 - Ecommerce Fashion -->
    <record id="task_001" model="task.management.task">
        <field name="name">Triển khai Website Thương Mại Điện Tử cho FashionHub</field>
        <field name="description"><![CDATA[
            <p><strong>Mô tả:</strong> Cài đặt và cấu hình website thương mại điện tử cho khách hàng FashionHub</p>
            <ul>
                <li>Setup server và database</li>
                <li>Cấu hình domain và SSL</li>
                <li>Import dữ liệu sản phẩm</li>
                <li>Test thanh toán online</li>
            </ul>
        ]]></field>
        <field name="partner_id" ref="customer_management.customer_ecommerce_fashion"/>
        <field name="order_id" ref="customer_management.order_001"/>
        <field name="start_date" eval="(DateTime.now() - timedelta(days=15)).strftime('%Y-%m-%d')"/>
        <field name="deadline" eval="(DateTime.now() - timedelta(days=5)).strftime('%Y-%m-%d')"/>
        <field name="priority">2</field>
        <field name="state">done</field>
        <field name="progress">100</field>
    </record>
    
